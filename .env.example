# Copy this file to .env and fill in values for local development.
# On the Pi, set these in /etc/royalmnl-timing-node.env instead.
# .env is gitignored — never commit real keys.

# --- Required ---
TIMING_NODE_ID=dev-node-1
TIMING_API_BASE_URL=http://localhost:3000
TIMING_API_KEY=dev-secret-key

# --- Optional (defaults shown) ---
READER_IP=192.168.1.200
READER_PORT=4000
TIMING_LOG_LEVEL=DEBUG

# TIMING_DB_PATH=~/.royalmnl-timing/outbox.db
# DEDUPE_WINDOW_SEC=20
# ASSIGNMENT_POLL_SEC=5
# ASSIGNMENT_POLL_STABLE_SEC=20
# SYNC_BATCH_SIZE=50
# SYNC_INTERVAL_SEC=1.5
# SYNC_MAX_RETRIES=5

# --- Reader debug ---
# DEBUG_FRAMES=1
